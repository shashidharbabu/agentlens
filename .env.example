# Copy this file to .env and fill in your keys.
# Then run:  source .env && python run_demo.py

# --- Required: Anthropic (Vision / Prompt / Critique agents) ----------
export STUB_MODE=0
export ANTHROPIC_API_KEY=sk-ant-YOUR-KEY-HERE
export ANTHROPIC_MODEL=claude-sonnet-4-5        # optional, this is the default

# --- Required: pick ONE image generation backend ----------------------

# Option A: Stability AI  (recommended — pay-as-you-go, ~$0.04/image)
export GENERATION_BACKEND=stability
export STABILITY_API_KEY=sk-YOUR-STABILITY-KEY-HERE

# Option B: Replicate SDXL  (uncomment to use instead)
# export GENERATION_BACKEND=replicate
# export REPLICATE_API_TOKEN=r8_YOUR-TOKEN-HERE

# Option C: Local open-source — NO API KEY, NO CREDITS needed
#   Uses Stable Diffusion 1.5 via the diffusers library.
#   Auto-detects Apple Silicon (MPS), NVIDIA (CUDA), or CPU.
#   Downloads model once (~4 GB) to ~/.cache/huggingface/ on first run.
#   Install deps first: pip install diffusers transformers accelerate
# export GENERATION_BACKEND=diffusers
# export LOCAL_SD_MODEL=runwayml/stable-diffusion-v1-5   # default
# export LOCAL_SD_MODEL=stabilityai/stable-diffusion-2-1 # better quality (~5 GB)
